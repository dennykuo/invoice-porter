{
    "name": "dennykuo/invoice-porter",
    "description": "台灣電子發票串接 PHP SDK，目前支援藍新（NewebPay/EZPay）發票與字軌管理",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ezpay",
        "newebpay",
        "invoice",
        "e-invoice",
        "einvoice",
        "taiwan",
        "taiwan-einvoice",
        "track",
        "藍新",
        "電子發票",
        "字軌"
    ],
    "authors": [
        {
            "name": "Denny"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.50",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "InvoicePorter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InvoicePorter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-clover build/logs/clover.xml --coverage-html build/coverage-html",
        "stan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "ci": [
            "@cs-check",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
